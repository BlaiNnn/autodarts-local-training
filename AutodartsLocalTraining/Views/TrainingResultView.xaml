<UserControl x:Class="AutodartsLocalTraining.WinUI.Views.TrainingResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding TrainingName}" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            <TextBlock Text="{Binding ScoreText}" FontSize="120" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding TrendText}" Foreground="{Binding TrendBrush}"
                       FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,16,0,48"/>
            <Button x:Name="ContinueButton" Width="200" Height="40" Command="{Binding ContinueCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
