<Window x:Class="AutodartsLocalTraining.TrainingSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autodarts Local Training - Select Training"
        Width="600" Height="450"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,0,0,16">
            <TextBlock Text="{Binding ConnectionText}" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="14" Margin="0,0,12,0"/>
            <Button Content="Disconnect" Padding="10,4"
                    Command="{Binding DisconnectCommand}"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="Training Programs" FontSize="22" FontWeight="Bold"
                    Margin="0,0,0,12"/>

        <ListBox ItemsSource="{Binding Programs}" SelectedItem="{Binding SelectedProgram}"
                  FontSize="16" DisplayMemberPath="Name"/>
    </DockPanel>
</Window>
