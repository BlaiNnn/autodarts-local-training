<Window x:Class="AutodartsLocalTraining.BoardSimulator.SimulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autodarts Simulator Console"
        Width="520" Height="560"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="16">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="SingleRadio" Content="Single" GroupName="Multiplier" Tag="1"
                         IsChecked="True" Checked="MultiplierChanged" Margin="0,0,16,0" VerticalAlignment="Center"/>
            <RadioButton x:Name="DoubleRadio" Content="Double" GroupName="Multiplier" Tag="2"
                         Checked="MultiplierChanged" Margin="0,0,16,0" VerticalAlignment="Center"/>
            <RadioButton x:Name="TripleRadio" Content="Triple" GroupName="Multiplier" Tag="3"
                         Checked="MultiplierChanged" VerticalAlignment="Center"/>
        </StackPanel>

        <UniformGrid Columns="5" Margin="0,0,0,12">
            <Button Content="1" Tag="1" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="2" Tag="2" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="3" Tag="3" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="4" Tag="4" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="5" Tag="5" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="6" Tag="6" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="7" Tag="7" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="8" Tag="8" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="9" Tag="9" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="10" Tag="10" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="11" Tag="11" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="12" Tag="12" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="13" Tag="13" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="14" Tag="14" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="15" Tag="15" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="16" Tag="16" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="17" Tag="17" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="18" Tag="18" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="19" Tag="19" Margin="4" Padding="10,6" Click="Number_Click"/>
            <Button Content="20" Tag="20" Margin="4" Padding="10,6" Click="Number_Click"/>
        </UniformGrid>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Bull (50)" Padding="10,4" Margin="0,0,6,0" Click="Bull_Click"/>
            <Button Content="25" Padding="10,4" Margin="0,0,6,0" Click="OuterBull_Click"/>
            <Button Content="Miss" Padding="10,4" Click="Miss_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Random throw" Padding="10,4" Margin="0,0,6,0" Click="Random_Click"/>
            <Button Content="Reset turn" Padding="10,4" Click="Reset_Click"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" FontSize="16" Margin="0,0,0,8"/>
        <TextBlock x:Name="ThrowsText" FontSize="16" TextWrapping="Wrap"/>
    </StackPanel>
</Window>
